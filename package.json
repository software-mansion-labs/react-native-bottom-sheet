{
  "name": "@swmansion/react-native-bottom-sheet",
  "version": "0.15.0-next.3",
  "description": "Provides bottom-sheet components for React Native.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "common",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "bun run --filter @swmansion/react-native-bottom-sheet-example",
    "clean": "del-cli lib",
    "prepare": "lefthook install && bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\""
  },
  "keywords": [
    "react-native",
    "android",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/software-mansion-labs/react-native-bottom-sheet.git"
  },
  "author": "Software Mansion",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/software-mansion-labs/react-native-bottom-sheet/issues"
  },
  "homepage": "https://github.com/software-mansion-labs/react-native-bottom-sheet",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@types/react": "19.2.15",
    "babel-plugin-react-compiler": "1.0.0",
    "del-cli": "6.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "lefthook": "2.1.9",
    "prettier": "3.8.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "0.41.0",
    "react-native-safe-area-context": "5.7.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-safe-area-context": ">=4.0.0"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "bun@1.3.14",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "ReactNativeBottomSheetSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "ios": {
      "componentProvider": {
        "BottomSheetView": "BottomSheetComponentView",
        "BottomSheetSurfaceView": "BottomSheetSurfaceComponentView"
      }
    },
    "android": {
      "javaPackageName": "com.swmansion.reactnativebottomsheet"
    }
  },
  "prettier": {
    "proseWrap": "always",
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
